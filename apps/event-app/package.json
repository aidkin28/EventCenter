{
	"name": "event-app",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"with-env": "dotenv -e ../../.env --",
		"with-env:prod": "dotenv -e ../../.env.production --",
		"dev": "pnpm with-env next dev --turbopack --port 9001",
		"build": "pnpm with-env next build",
		"build:standalone": "STANDALONE=true pnpm with-env next build",
		"build:standalone:prod": "STANDALONE=true pnpm with-env:prod next build",
		"start": "pnpm with-env next start",
		"start:standalone": "node .next/standalone/apps/event-app/server.js",
		"lint": "pnpm with-env next lint",
		"drizzle-kit": "pnpm with-env drizzle-kit",
		"db:push": "pnpm drizzle-kit push",
		"db:generate": "pnpm drizzle-kit generate",
		"db:sync": "pnpm db:push && pnpm db:generate"
	},
	"dependencies": {
		"@azure/communication-email": "^1.1.0",
		"@azure/storage-blob": "^12.26.0",
		"@azure/web-pubsub": "^1.2.0",
		"@azure/web-pubsub-client": "^1.0.2",
		"@better-auth/drizzle-adapter": "^1.5.3",
		"@langchain/core": "^1.1.30",
		"@langchain/langgraph": "^1.2.0",
		"@langchain/openai": "^1.2.12",
		"@radix-ui/react-dialog": "catalog:",
		"@radix-ui/react-label": "^2.1.2",
		"@radix-ui/react-slot": "catalog:",
		"@tabler/icons-react": "^3.31.0",
		"@tanstack/react-query": "^5.90.21",
		"@upstash/ratelimit": "^0.3.9",
		"@upstash/redis": "^1.20.1",
		"better-auth": "^1.3.34",
		"class-variance-authority": "catalog:",
		"clsx": "catalog:",
		"common": "workspace:*",
		"date-fns": "^4.1.0",
		"dotenv-cli": "^8.0.0",
		"drizzle-orm": "0.44.7",
		"framer-motion": "catalog:",
		"lucide-react": "catalog:",
		"motion": "^12.0.0",
		"next": "catalog:",
		"openai": "^4.58.2",
		"papaparse": "^5.5.3",
		"pg": "^8.17.2",
		"qrcode": "^1.5.3",
		"react": "catalog:",
		"react-dom": "catalog:",
		"sonner": "catalog:",
		"tailwind-merge": "catalog:",
		"xlsx": "^0.18.5",
		"zod": "catalog:",
		"zustand": "^4.3.7"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "catalog:",
		"@types/node": "catalog:",
		"@types/papaparse": "^5.5.2",
		"@types/pg": "^8.16.0",
		"@types/qrcode": "^1.5.0",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"drizzle-kit": "0.31.8",
		"tailwindcss": "catalog:",
		"typescript": "catalog:"
	}
